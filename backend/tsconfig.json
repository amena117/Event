{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "esModuleInterop": true,               // ← This fixes TS1259 for express/cors
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true   // Helps with dotenv & others
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}